# Apex Host production example.
# Copy to .env.production and replace every placeholder before going live.

APP_ENV=production
ENVIRONMENT=production
DRY_RUN=false
DEPLOY_MODE=docker
ENABLE_DOCKER_DEPLOYS=true
ENABLE_BUILD_COMMANDS=true
AUTO_CREATE_TABLES=false

PUBLIC_APP_URL=https://host.example.com
API_URL=https://host.example.com/api
BACKEND_CORS_ORIGINS=https://host.example.com
BASE_DOMAIN=apps.example.com

POSTGRES_DB=apex_host
POSTGRES_USER=apex_host
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql+psycopg://apex_host:replace-with-strong-postgres-password@postgres:5432/apex_host
REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-with-64-hex-secret
JWT_SECRET=replace-with-64-hex-secret
ENCRYPTION_KEY=replace-with-64-hex-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-temporary-strong-admin-password
ADMIN_NAME=Apex Admin
ADMIN_SIGNUP_CODE=
PUBLIC_REGISTRATION_ENABLED=false

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=https://host.example.com/api/github/oauth/callback
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret

CERTBOT_ENABLED=true
CERTBOT_EMAIL=admin@example.com
DOCKER_NETWORK=apex-host-internal
DOCKER_APPS_NETWORK=apex-host-apps
NGINX_SITES_DIR=/etc/nginx/project-sites
NGINX_UPSTREAM_HOST=host.docker.internal
NGINX_TEST_COMMAND=docker exec apex-host-nginx nginx -t
NGINX_RELOAD_COMMAND=docker exec apex-host-nginx nginx -s reload

DATA_DIR=/data
BACKUP_PATH=/data/backups
BACKUP_RETENTION_DAYS=14
