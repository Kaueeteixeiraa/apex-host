# Daily Apex Host database backup at 03:15.
# Install with: sudo crontab -e
# Prefer the systemd timers installed by scripts/install.sh.
# Cron fallback:
15 3 * * * cd /opt/apex-host && HOST_BACKUP_PATH=/opt/apex-host/data/backups BACKUP_RETENTION_DAYS=14 /usr/bin/env bash scripts/backup_postgres.sh >> /opt/apex-host/data/backups/backup-cron.log 2>&1
