# Apex Host environment
# Copy to .env and replace every production secret. Never commit .env.

APP_NAME=Apex Host
ENVIRONMENT=development
PUBLIC_APP_URL=http://localhost:5173
API_URL=http://localhost:8000/api
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security
SECRET_KEY=change-this-long-random-secret-at-least-32-chars
JWT_SECRET=change-this-jwt-secret-at-least-32-chars
ENCRYPTION_KEY=change-this-encryption-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@apex.local
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Apex Admin
ADMIN_SIGNUP_CODE=
PUBLIC_REGISTRATION_ENABLED=true

# Database and queue
POSTGRES_DB=apex_host
POSTGRES_USER=apex_host
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql+psycopg://apex_host:change-this-postgres-password@postgres:5432/apex_host
REDIS_URL=redis://redis:6379/0
DEPLOY_QUEUE_NAME=apex-host-deploys
USE_REDIS_DEPLOY_QUEUE=true
AUTO_CREATE_TABLES=true

# Domains and URLs
BASE_DOMAIN=apexhost.local
CERTBOT_EMAIL=

# Deploys
DEPLOY_MODE=dry-run
DRY_RUN=true
ENABLE_DOCKER_DEPLOYS=false
ENABLE_BUILD_COMMANDS=false
DOCKER_NETWORK=apex-host-internal
DOCKER_APPS_NETWORK=apex-host-apps
DOCKER_CPU_LIMIT=1
DOCKER_MEMORY_LIMIT=512m
DEPLOY_TIMEOUT_SECONDS=900
ALLOWED_COMMAND_PREFIXES=npm,pnpm,yarn,node,python,pip,uvicorn,gunicorn

# Nginx and SSL
NGINX_SITES_DIR=
NGINX_TEST_COMMAND=nginx -t
NGINX_RELOAD_COMMAND=nginx -s reload
CERTBOT_ENABLED=false

# Monitoring and availability
HEALTH_MONITOR_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=60
DEFAULT_HEALTH_CHECK_TIMEOUT_SECONDS=5

# SMTP and alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Backups
DATA_DIR=/data
BACKUP_PATH=/data/backups
BACKUP_RETENTION_DAYS=14

# Frontend build
VITE_API_URL=http://localhost:8000/api
